---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import { ProjectList } from "@/components/project-list";
import { Navbar } from "@/components/navbar";
import Footer from "@/components/footer.astro";
import MailSmall from "@/components/icons/MailSmall.astro";
import { H1, P } from "@/layouts/text-wrapper";
import { HeroHighlight } from "@/components/ui/hero-highlight";
import { HoverBorderGradient } from "@/components/ui/hover-border-gradient";
import { GlowySpotlightWrapper } from "@/components/spotlight-glowy-wrapper";
import { FirstScene } from "../components/three/FirstScene";
import MagicBento from "@/components/MagicBento";
import TargetCursor from "@/components/TargetCursor";
const projects = await getCollection("projects");
---

<Layout title="Juan Saugar - Portfolio">
  <HeroHighlight client:load>
    <Navbar client:idle />

    <main
      class="flex flex-col items-center justify-center w-[98vw] mx-auto overflow-y-auto overflow-x-hidden scroll-smooth"
    >
      <section id="home" class="min-h-screen flex items-center justify-center">
        <div
          class="mx-auto flex lg:flex-row flex-col pt-20 lg:pt-0 justify-start items-center"
        >
          <div
            class="flex flex-col gap-y-5 max-w-2xl mx-10 mb-10 justify-center items-start"
          >
            <H1
              text="h1"
              className="text-4xl sm:text-6xl text-center sm:text-start font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-violet-500 to-slate-800 dark:from-yellow-300 dark:to-emerald-500"
              client:load
            />

            <P
              text="description"
              className="[&>strong]:text-violet-300 [&>strong]:font-bold text-base sm:text-lg text-center lg:text-start line-clamp-3"
              client:load
            />

            <a
              href="mailto:juancarlossa.agullo@gmail.com"
              class="w-fit cursor-target"
            >
              <div class="flex w-fit justify-center lg:justify-start">
                <HoverBorderGradient
                  client:load
                  containerClassName="rounded-full"
                  as="div"
                  duration={1}
                  className="dark:bg-neutral-900 gap-x-3 bg-violet-800 flex items-center justify-center px-4 py-2"
                >
                  <MailSmall />
                  Contact me
                </HoverBorderGradient>
              </div>
            </a>
          </div>
          <FirstScene client:idle />
        </div>
      </section>
      <TargetCursor
        spinDuration={20}
        hideDefaultCursor
        hoverDuration={2}
        client:only
        parallaxOn
      />
      <section id="projects" class="relative w-full py-10 min-h-screen">
        <GlowySpotlightWrapper client:idle>
          <ProjectList
            projects={projects.map(({ data }) => data)}
            client:idle
          />
        </GlowySpotlightWrapper>
      </section>

      <section id="contact" class="">
        <Footer />
      </section>
    </main>
  </HeroHighlight>
</Layout>

<script>
  import Lenis from "lenis";

  const lenis = new Lenis({
    duration: 1,
    easing: (t) => t * (2 - t),
    orientation: "vertical",
    wheelMultiplier: 1,
  });
  function raf(time: number) {
    lenis.raf(time);
    requestAnimationFrame(raf);
  }
  requestAnimationFrame(raf);

  // ----- Scroll automático por secciones -----
  const sections = Array.from(
    document.querySelectorAll("section"),
  ) as HTMLElement[];
  let currentIndex = 0;
  let isScrolling = false;

  function scrollToSection(index: number) {
    if (index < 0) index = 0;
    if (index >= sections.length) index = sections.length - 1;
    currentIndex = index;
    isScrolling = true;
    lenis.scrollTo(sections[currentIndex], { duration: 1 });
    setTimeout(() => (isScrolling = false), 1200); // bloquear input hasta terminar animación
  }

  // Usar evento de Lenis para detectar movimiento del scroll
  lenis.on("scroll", ({ velocity }) => {
    // Solo usamos esto para monitorear o animaciones; no para decidir sección
  });

  // Detectar input del trackpad/rueda dentro del propio Lenis
  window.addEventListener("keydown", (e) => {
    if (isScrolling) return;
    if (e.key === "ArrowDown") scrollToSection(currentIndex + 1);
    if (e.key === "ArrowUp") scrollToSection(currentIndex - 1);
  });
</script>
